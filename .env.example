# ============================================================
# WeGoTwo · Environment variables
# Copy this file to .env.local and fill in real values.
# Never commit .env.local to git.
# ============================================================

# --- Supabase ---
# From Supabase dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# --- Access gate ---
# JSON object mapping user name -> access code.
# Example: {"kirill":"123456","marina":"abcdef"}
# Keep this secret. Rotate by updating the env var on Vercel and redeploying.
WEGOTWO_ACCESS_CODES={"kirill":"CHANGE_ME","marina":"CHANGE_ME"}

# Secret used to sign the unlock cookie.
# Generate with: openssl rand -base64 48
WEGOTWO_COOKIE_SECRET=CHANGE_ME_base64_48_bytes

# --- Cowork ingest ---
# Bearer token for /api/admin/ingest. Generate: openssl rand -hex 32
INGEST_TOKEN=CHANGE_ME_hex_32_bytes

# --- Gemini ---
# Google AI Studio -> Get API key
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-3.1-flash-lite-preview

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
